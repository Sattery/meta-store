# ___ meta-store .gitignore ___

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Runtime data (user-specific scan results)
.metastore/*
!.metastore/.gitkeep
data/*
!data/.gitkeep

# Dev notes (keep local only)
DEVELOPMENT.md

# Local test files
meta.json
